import java.util.ArrayList;
import java.util.List;

public class Solution {
    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        List<List<Integer>> result = new ArrayList<>(); // To store all unique combinations
        backtrack(result, new ArrayList<>(), candidates, target, 0); // Start backtracking
        return result; // Return the list of combinations
    }

    private void backtrack(List<List<Integer>> result, List<Integer> current, int[] candidates, int target, int start) {
        if (target == 0) {
            result.add(new ArrayList<>(current)); // Found a valid combination
            return;
        }
        if (target < 0) {
            return; // Exceeded the target, no valid combination
        }

        // Iterate through candidates starting from 'start' index
        for (int i = start; i < candidates.length; i++) {
            current.add(candidates[i]); // Include the candidate
            backtrack(result, current, candidates, target - candidates[i], i); // Recur with reduced target, allowing same candidate
            current.remove(current.size() - 1); // Backtrack to explore other combinations
        }
    }

    public static void main(String[] args) {
        Solution solution = new Solution();
        
        // Test cases
        int[] candidates1 = {2, 3, 6, 7};
        int target1 = 7;
        System.out.println(solution.combinationSum(candidates1, target1)); // Output: [[2, 2, 3], [7]]

        int[] candidates2 = {2, 3, 5};
        int target2 = 8;
        System.out.println(solution.combinationSum(candidates2, target2)); // Output: [[2, 2, 2, 2], [2, 3, 3], [3, 5]]

        int[] candidates3 = {2};
        int target3 = 1;
        System.out.println(solution.combinationSum(candidates3, target3)); // Output: []
    }
}
